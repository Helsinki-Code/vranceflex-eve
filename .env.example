# Required by the lead-researcher subagent for Parallel FindAll and Task MCP.
# Configure the real value in the local environment or deployment secret manager.
PARALLEL_API_KEY=

# Optional for local AI Gateway access. Vercel deployments can use project OIDC.
AI_GATEWAY_API_KEY=

# Managed PostgreSQL connection. Required for durable production persistence.
DATABASE_URL=

# First-party authentication. Use at least 32 random characters and keep it
# server-side. Rotating this invalidates outstanding OTP hashes.
AUTH_SECRET=

# Resend platform account. Used ONLY for signup/password OTPs and team-invite
# email — never for client outreach. Outreach email and SMS are BYOK: each
# workspace connects its own Resend/Twilio account from Settings → Integrations
# (stored encrypted in the database, see CREDENTIALS_ENCRYPTION_KEY below).
# There is no global outreach fallback and no global Twilio config anymore.
RESEND_API_KEY=
RESEND_FROM_EMAIL=VranceFlex <auth@example.com>

# AES-256-GCM key (32 bytes, base64url-encoded) used to encrypt each client
# workspace's connected Resend/Twilio credentials at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Never reuse AUTH_SECRET for this — rotating one must not affect the other.
CREDENTIALS_ENCRYPTION_KEY=

# Bearer token Vercel Cron sends as `Authorization: Bearer $CRON_SECRET` when it calls
# app/api/cron/delivery. Generate a long random value; it is never exposed to the browser.
CRON_SECRET=

# Physical mailing address included in outbound outreach email footers (CAN-SPAM
# requirement). Plain text, e.g. "Acme Inc, 123 Main St, Springfield, ST 00000".
COMPANY_MAILING_ADDRESS=

# Public base URL of this deployment, used to build the one-click unsubscribe
# link embedded in outreach email (app/api/unsubscribe/[messageId]).
# Example: https://app.vranceflex.com
APP_BASE_URL=

# Temporary local/demo campaign persistence is enabled automatically outside production.
# Production APIs stay closed until authentication is configured. Set this only for an
# intentionally public, non-sensitive demonstration deployment.
VRANCEFLEX_DEMO_MODE=false

# Stripe billing (scaffolding). Safe to leave blank until a live account exists —
# the billing page shows "setup mode" copy and disables checkout when unset.
# STRIPE_PRICE_ID_PRO is a placeholder Price ID; replace with a real one when ready.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# Production services still to configure in the hosting platform, never in Git:
# ERROR_MONITORING_DSN=
