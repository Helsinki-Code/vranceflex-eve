# Required by the lead-researcher subagent for Parallel FindAll and Task MCP.
# Configure the real value in the local environment or deployment secret manager.
PARALLEL_API_KEY=

# Optional for local AI Gateway access. Vercel deployments can use project OIDC.
AI_GATEWAY_API_KEY=

# Managed PostgreSQL connection. Required for durable production persistence.
DATABASE_URL=

# First-party authentication. Use at least 32 random characters and keep it
# server-side. Rotating this invalidates outstanding OTP hashes.
AUTH_SECRET=

# Resend is used server-side for signup verification and password reset OTPs.
RESEND_API_KEY=
RESEND_FROM_EMAIL=VranceFlex <auth@example.com>

# Temporary local/demo campaign persistence is enabled automatically outside production.
# Production APIs stay closed until authentication is configured. Set this only for an
# intentionally public, non-sensitive demonstration deployment.
VRANCEFLEX_DEMO_MODE=false

# Production services still to configure in the hosting platform, never in Git:
# STRIPE_SECRET_KEY=
# OUTREACH_EMAIL_PROVIDER_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# ERROR_MONITORING_DSN=
