# Copy to .env.test and point at a disposable PostgreSQL database (never the
# app's development or production database). DB-backed test suites
# (lib/server/auth-store.test.ts, lib/server/delivery-worker.test.ts) use real
# Drizzle transactions and a Postgres advisory lock that in-memory mocks can't
# faithfully reproduce, so they connect to this database directly and truncate
# their tables between tests.
#
# Before running `npm test`, migrate this database once:
#   DATABASE_URL="$TEST_DATABASE_URL" npm run db:migrate
#
# Without TEST_DATABASE_URL set, the DB-backed suites are skipped automatically
# (npm test still runs the pure-logic suites, e.g. reply-classifier.test.ts).
TEST_DATABASE_URL=postgres://localhost/vranceflex_test

# Required by lib/server/auth-crypto.ts for OTP/session hashing in tests.
AUTH_SECRET=test-auth-secret-at-least-32-characters-long
